# ========================================
# LIS 物流系统 Docker 环境变量配置示例
# ========================================

# -------------------
# MySQL 配置
# -------------------
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=hhhh
MYSQL_USER=hhhh
MYSQL_PASSWORD=hhhh123
MYSQL_PORT=3306

# -------------------
# 应用配置
# -------------------
CONFIG_PORT=8808
JAVA_OPTS=-Xmx1024M -Xms256M

# -------------------
# 说明
# -------------------
# 1. 将此文件复制为 .env 并根据实际情况修改
# 2. docker-compose.yml 会自动读取 .env 文件中的变量
# 3. 所有变量都有默认值，未设置时使用默认值
